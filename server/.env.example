# Mailjet Configuration
# Obtén tus credenciales en https://www.mailjet.com/
MJ_APIKEY_PUBLIC=tu_api_key_public
MJ_APIKEY_PRIVATE=tu_api_key_private

# Email del remitente (debe estar verificado en Mailjet)
MJ_SENDER_EMAIL=tu_email@ejemplo.com

# Email del destinatario (donde recibirás los mensajes)
MJ_RECIPIENT_EMAIL=galbat.agency@gmail.com

# Puerto del servidor
PORT=3000
